# 运行环境：dev / prod / test
APP_ENV=dev

# 后端监听端口，仅 run.py 使用
PORT=8000

# 对外访问域名，用于生成密码重置、飞书 OAuth 回调等外部链接
APP_DOMAIN=

# 应用密钥。生产部署必须改成随机长字符串
APP_SECRET_KEY=change-me

# 允许跨域来源。开发环境通常保留 Vite 地址；同域部署时可按需收紧
ALLOWED_ORIGINS=["http://localhost:5173"]

# 数据库与日志
DATABASE_PATH=data/database.db
LOG_LEVEL=info
LOG_DIR=logs
LOG_ROTATION=20 MB
LOG_RETENTION=14 days
LOG_SERIALIZE=false

# 前端请求后端的 API 前缀。同域部署保持 /api 即可
VITE_API_BASE_URL=/api

# 首个管理员账号。对外部署前必须修改默认密码
INIT_ADMIN_NAME=admin
INIT_ADMIN_PASSWORD=change-me-admin-password
INIT_ADMIN_EMAIL=admin@example.com

# 是否开放公开注册。自托管部署默认关闭，由管理员创建用户
ENABLE_PUBLIC_REGISTRATION=false

# 飞书图床配置
IMAGE_HOST_FEISHU_APP_ID=
IMAGE_HOST_FEISHU_APP_SECRET=
IMAGE_HOST_FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
IMAGE_HOST_FEISHU_OAUTH_SCOPE=offline_access drive:drive
IMAGE_HOST_FEISHU_OAUTH_REFRESH_BEFORE_EXPIRY_SECONDS=3600
IMAGE_HOST_CACHE_DIR=data/image_cache
IMAGE_HOST_MAX_UPLOAD_MB=10
IMAGE_HOST_CACHE_TTL_HOURS=168
IMAGE_HOST_ACCESS_FLUSH_INTERVAL_SECONDS=60
IMAGE_HOST_PUBLIC_BASE_URL=http://localhost:8000

# 邮件配置，可选。未配置时，开发/测试环境会把验证码和重置链接写入日志
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=465
MAIL_USE_SSL=true
MAIL_USE_TLS=false
MAIL_TIMEOUT=5
MAIL_SENDER_EMAIL=
MAIL_SENDER_PASSWORD=
MAIL_SENDER_NAME=

# Cloudflare Turnstile 人机校验，可选
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_TIMEOUT_SECONDS=4
VITE_TURNSTILE_SITE_KEY=

# 二步验证配置
TWO_FACTOR_CHALLENGE_TTL_MINUTES=5
TWO_FACTOR_SETUP_TTL_MINUTES=10
TWO_FACTOR_ISSUER_NAME=Feishu Image Host
TWO_FACTOR_ENCRYPTION_KEY=change-me-2fa-encryption-key
TWO_FACTOR_BACKUP_CODE_COUNT=8
TWO_FACTOR_MAX_VERIFY_ATTEMPTS=5

# 旧全栈模板能力的兼容开关。开源图床默认不启用
ENABLE_EXAMPLE_MODULE=false
ENABLE_OAUTH_LOGIN=false
ENABLE_OAUTH_PROVIDER=false
ENABLE_SCOPE_MANAGEMENT=false
ENABLE_DEV_PROVIDER_RUNTIME=false
ENABLE_EXTERNAL_PROVIDER_REGISTRY=false
OAUTH_LIST=[]
EXTERNAL_PROVIDER_MOCK_LIST=[]
